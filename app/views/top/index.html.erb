<header>
    <div class="logo">One Step</div>
    <div class="nav-links">
        <% if user_signed_in? %>
            <%= link_to 'マイページ', profile_path, class: "nav-link" %>
            <span>ようこそ<%= current_user.name %> さん</span>
            <%= link_to 'Logout', destroy_user_session_path, data: { "turbo-method": :delete } %>
        <% else %>
            
            <%= link_to 'Login', new_user_session_path %>
        <% end %>
    </div>
</header>

<section class="goal-section">
    <div class="goal-label">Current Long-term Goal</div>
    <div class="goal-content"><%= current_user.long_term_goal %></div>
</section>

<div class="container">
    <div class="calendar-card">
       <div class="calendar-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
    <%# 先月へのリンク %>
    <%= link_to '＜', root_path(year: @display_date.prev_month.year, month: @display_date.prev_month.month), class: "nav-btn" %>

    <div style="text-align: center;">
        <h2 style="margin: 0;"><%= @display_date.strftime('%Y年 %-m月') %></h2>
        <span style="font-size: 0.8rem; color: #888;">今月の達成: <%= @actions.count %>回 ⭐</span>
    </div>

    <%# 来月へのリンク %>
    <%= link_to '＞', root_path(year: @display_date.next_month.year, month: @display_date.next_month.month), class: "nav-btn" %>
</div>

<div class="calendar-grid">
    <div class="day-label">Sun</div><div class="day-label">Mon</div><div class="day-label">Tue</div><div class="day-label">Wed</div><div class="day-label">Thu</div><div class="day-label">Fri</div><div class="day-label">Sat</div>
    
    <%# コントローラーで計算した「始まりの日」から「終わりの日」まで1日ずつループ %>
    <% (@start_date..@end_date).each do |date| %>
        <%# その日のデータが @actions の中にあるかチェック %>
        <% action = @actions.find { |a| a.date == date } %>
        
        <%# クラスの付け替え（今月以外の日、今日、保存済み） %>
        <% day_classes = [] %>
        <% day_classes << 'completed' if action %>
        <% day_classes << 'today' if date == @today %>
        <% day_classes << 'other-month' if date.month != @today.month %>
        
        <div class="day <%= day_classes.join(' ') %>" 
            onclick="openModal(
  '<%= date %>',
  '<%= j action&.content %>',
  '<%= j action&.reflection %>',
  '<%= j action&.tomorrow_goal %>',
  '<%= action&.id %>'
)">
            <%= date.day %>
        </div>
    <% end %>
</div>
    </div>
</div>

<div class="container">
    <h3>これまでの歩み</h3>
    <ul>
      <% @actions.each do |action| %>
        <li><%= action.date %>: <%= action.content %> ⭐</li>
      <% end %>
    </ul>
</div>

<div id="actionModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <div class="modal-title" id="modalDateDisplay">日付</div>
        
        <%# Railsの本物のフォーム作成用コード %>
        <%= form_with(model: Action.new, scope: :user_action, url:user_actions_path,local: true, id: 'action-form', data: { turbo: false }) do |f| %>
            <%# JavaScriptから日付を渡すための隠し入力欄 %>
            <%= f.hidden_field :date, id: 'modalDateInput' %>

            <div class="form-group">
    <label>☀️ 今日のAction</label>
    <%= f.text_field :content, id: 'contentField', placeholder: "例：RailsのDB設計を30分進める", required: true %>
</div>
<div class="form-group">
    <label>🌙 今日の振り返り</label>
    <%= f.text_area :reflection, id: 'reflectionField', placeholder: "今日できたこと、感じたことをメモ" %>
</div>
<div class="form-group">
    <label>🚀 明日の展望</label>
    <%= f.text_field :tomorrow_goal, id: 'goalField', placeholder: "明日、最高のスタートを切るために一言" %>
</div>

           <div class="modal-footer" style="display: flex; gap: 10px; margin-top: 1.5rem;">
        <%= f.submit "一歩進む", id: 'submit-btn', class: "submit-btn" %>
            </div>
</div>
        <% end %>
    </div>
</div>

<script>
    // これ一つで「新規」と「編集」の両方をこなす賢い関数
    function openModal(date, content, reflection, tomorrowGoal, actionId) {
    // 既存の隠しPATCH入力をリセット
    const oldMethod = document.querySelector('input[name="_method"]');
    if (oldMethod) oldMethod.remove();

    document.getElementById('modalDateDisplay').innerText = date + " の記録";
    document.getElementById('modalDateInput').value = date;
    document.getElementById('contentField').value = content || "";
    document.getElementById('reflectionField').value = reflection || "";
    document.getElementById('goalField').value = tomorrowGoal || "";

    const form = document.getElementById('action-form');
    const submitBtn = document.getElementById('submit-btn');

    const csrfToken = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    let csrfInput = form.querySelector('input[name="authenticity_token"]');
    if (csrfInput) {
        csrfInput.value = csrfToken;
    }

    if (actionId && actionId !== "" && actionId !== "undefined") {
        // 【編集モード】
        form.action = `/user_actions/${actionId}`;
        const methodInput = document.createElement('input');
        methodInput.type = 'hidden';
        methodInput.name = '_method';
        methodInput.value = 'patch';
        form.appendChild(methodInput);
        submitBtn.value = "内容を更新する";
    } else {
        // 【新規作成モード】
        form.action = '/user_actions';
        submitBtn.value = "一歩進む";
    }
    document.getElementById('actionModal').style.display = 'flex';
}
</script>